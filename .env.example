#
# NemoClaw Configuration Template
# Copy this file to .env and customize values as needed.
# The installer and onboard command will automatically load .env if present.

# ==============================================================================
# Repository Configuration
# ==============================================================================

# Git repository URL for NemoClaw source (used during installation)
# Default: https://github.com/NVIDIA/NemoClaw.git
# Set this to install from a forked repository
#NEMOCLAW_REPO_URL=https://github.com/YOUR_ORG/NemoClaw.git

# Git branch or tag to install
# Default: latest
#NEMOCLAW_INSTALL_TAG=main

# ==============================================================================
# Container Image Registry Configuration
# ==============================================================================
# NemoClaw uses THREE types of container images:
# 1. Sandbox Image - The OpenClaw agent container (runs your AI assistant)
# 2. Cluster Image - The k3s cluster container (runs the OpenShell gateway)
# 3. Gateway Image - Same as cluster image (OpenShell gateway service)

# --- Sandbox Image Configuration ---
# Container image registry for OpenClaw sandbox images
# Default: ghcr.io/nvidia/openshell-community/sandboxes
# Useful for corporate artifactory or private registry
#NEMOCLAW_SANDBOX_IMAGE_REGISTRY=your-artifactory.example.com/nvidia/sandboxes

# Full sandbox image reference (overrides registry + image name)
# If set, this takes precedence over NEMOCLAW_SANDBOX_IMAGE_REGISTRY
#NEMOCLAW_SANDBOX_IMAGE=your-registry.example.com/openclaw:custom-tag

# --- Cluster/Gateway Image Configuration ---
# Container image registry for OpenShell cluster images
# Default: ghcr.io/nvidia/openshell
# The version tag is automatically appended based on installed OpenShell version
#NEMOCLAW_CLUSTER_IMAGE_REGISTRY=your-artifactory.example.com/nvidia/openshell

# NOTE: Full cluster image override (NEMOCLAW_CLUSTER_IMAGE) is not yet implemented.
# Use NEMOCLAW_CLUSTER_IMAGE_REGISTRY to change the registry only.

# ==============================================================================
# Timeout Configuration (in seconds unless otherwise noted)
# ==============================================================================

# Gateway startup timeout (seconds)
# Default: 600 (10 minutes)
# Increase this for slower Docker Desktop or k3s environments
#NEMOCLAW_GATEWAY_START_TIMEOUT=900

# Local inference timeout for Ollama, vLLM, NIM (seconds)
# Default: 180 (3 minutes)
#NEMOCLAW_LOCAL_INFERENCE_TIMEOUT=300

# Agent execution timeout (seconds)
# Default: configured in blueprint
#NEMOCLAW_AGENT_TIMEOUT=600

# ==============================================================================
# Polling and Retry Configuration
# ==============================================================================

# Health check poll interval (seconds)
# Default: 5 for x86_64, 10 for ARM64
# Increase for slower systems like Docker Desktop
#NEMOCLAW_HEALTH_POLL_INTERVAL=10

# Health check poll count (number of attempts)
# Default: 12 for x86_64, 30 for ARM64
# Increase to wait longer before timing out
#NEMOCLAW_HEALTH_POLL_COUNT=60

# Gateway startup poll interval (seconds)
# Default: same as NEMOCLAW_HEALTH_POLL_INTERVAL
# How often to check if the gateway is ready during startup
#NEMOCLAW_GATEWAY_START_POLL_INTERVAL=15

# Gateway startup poll count (number of attempts)
# Default: same as NEMOCLAW_HEALTH_POLL_COUNT
# How many times to check before giving up
#NEMOCLAW_GATEWAY_START_POLL_COUNT=40

# ==============================================================================
# Docker Image Pull/Build Timeouts (milliseconds)
# ==============================================================================

# Docker image pull timeout (milliseconds)
# Default: 600000 (10 minutes)
# Increase for slow networks or large images
#NEMOCLAW_PULL_TIMEOUT_MS=900000

# Docker image build timeout (milliseconds)
# Default: 300000 (5 minutes)
#NEMOCLAW_BUILD_TIMEOUT_MS=600000

# Docker image inspect timeout (milliseconds)
# Default: 30000 (30 seconds)
#NEMOCLAW_INSPECT_TIMEOUT_MS=60000

# ==============================================================================
# Installation Configuration
# ==============================================================================

# Non-interactive mode (skip prompts)
#NEMOCLAW_NON_INTERACTIVE=1

# Accept third-party software license
#NEMOCLAW_ACCEPT_THIRD_PARTY_SOFTWARE=1

# Sandbox name to create/use
#NEMOCLAW_SANDBOX_NAME=my-assistant

# Inference provider selection
# Options: build | openai | anthropic | gemini | ollama | custom | nim-local | vllm
#NEMOCLAW_PROVIDER=build

# Inference model
#NEMOCLAW_MODEL=nvidia/nemotron-3-super-120b-a12b

# Network policy mode
# Options: suggested | custom | skip
#NEMOCLAW_POLICY_MODE=suggested

# Policy presets (comma-separated)
# Options: slack, discord, telegram, brave, pypi, npm, etc.
#NEMOCLAW_POLICY_PRESETS=slack,pypi,npm

# ==============================================================================
# Advanced Configuration
# ==============================================================================

# Force fresh onboarding (discard existing session)
#NEMOCLAW_FRESH=1

# Recreate existing sandbox
#NEMOCLAW_RECREATE_SANDBOX=1

# Abort if active sandbox sessions exist
#NEMOCLAW_SINGLE_SESSION=1

# Show experimental/local options
#NEMOCLAW_EXPERIMENTAL=1

# ==============================================================================
# API Keys and Credentials
# ==============================================================================

# NVIDIA API Key
#NVIDIA_API_KEY=your-api-key-here

# OpenAI API Key
#OPENAI_API_KEY=your-openai-key-here

# Anthropic API Key
#ANTHROPIC_API_KEY=your-anthropic-key-here

# Brave Search API Key (optional)
#BRAVE_API_KEY=your-brave-key-here

# Bot tokens for messaging integrations (optional)
#DISCORD_BOT_TOKEN=your-discord-token
#SLACK_BOT_TOKEN=your-slack-token
#TELEGRAM_BOT_TOKEN=your-telegram-token

# Chat UI URL (optional)
#CHAT_UI_URL=http://localhost:3000
